  section::before {
    content: "";
    position: absolute;
    height: 100px;
    width: 100px;
    z-index: 1;
    background: red;
  }

  section::after {
    content: "";
    position: absolute;
    bottom: 0;
    right: 0;
    height: 100px;
    width: 100px;
    z-index: 1;
    background: blue;
  }
</style> -->
</section>
